# GitHub token for API access (required)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ElizaCloud - Unified Model Gateway (RECOMMENDED)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# One API key for all models: Claude, GPT, Gemini
# Get your key at https://elizacloud.ai
ELIZACLOUD_API_KEY=your-elizacloud-key-here

# PRR automatically uses ElizaCloud when the key is set.
# No need to set PRR_LLM_PROVIDER - it auto-detects.

# Default model (optional, defaults to gpt-4o):
# PRR_LLM_MODEL=gpt-4o

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Alternative: Direct Provider Keys
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# If you prefer direct Anthropic/OpenAI keys instead of ElizaCloud:
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Optionally force a specific provider (auto-detects if not set):
# PRR_LLM_PROVIDER=elizacloud  # or 'anthropic' or 'openai'

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Other Options
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Default fixer tool: elizacloud, cursor, opencode, claude-code, aider, codex, llm-api
# RECOMMENDED: Leave commented out for auto-detect.
# PRR_TOOL=elizacloud

# Extended thinking token budget for Claude models (optional)
# PRR_THINKING_BUDGET=10000
