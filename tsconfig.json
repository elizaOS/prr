{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["shared/**/*", "tools/prr/**/*", "tools/pill/**/*", "tools/split-plan/**/*", "tools/split-exec/**/*", "tools/split-rewrite-plan/**/*", "tools/story/**/*", "tools/model-catalog/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist"]
}
